{
  "name": "luxhub",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "HOST=0.0.0.0 next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:anchor": "cd Solana-Anchor && anchor test",
    "env:check": "node scripts/validate-env.js",
    "lint:compliance": "node scripts/lint-legal-language.cjs",
    "build:all": "npm run build && cd Solana-Anchor && anchor build",
    "analyze": "ANALYZE=true next build --webpack",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 5000",
      "prettier --write",
      "node scripts/lint-legal-language.cjs"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
